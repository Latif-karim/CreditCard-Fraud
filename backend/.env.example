SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-jwt
FRONTEND_URL=http://localhost:3000
OAUTH_REDIRECT_URI=http://127.0.0.1:5000/auth

# Optional: Neon / PostgreSQL connection string.
# Use the pooled connection URL from Neon and keep sslmode=require.
# Example:
# DATABASE_URL=postgresql://user:password@ep-example-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Demo data auto-seeding runs by default for local SQLite only.
# Keep false for Neon/PostgreSQL so startup is fast and migrations control schema setup.
AUTO_SEED_DEMO_DATA=false

# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Authorized redirect URI: http://127.0.0.1:5000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub → Settings → Developer settings → OAuth Apps
# Authorization callback URL: http://127.0.0.1:5000/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# If Google sign-in fails with SSL errors on Windows, keep true and run: pip install certifi
# Only set false for local debugging (not recommended for production)
OAUTH_SSL_VERIFY=true
